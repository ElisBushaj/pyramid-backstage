# mock-ops-core — dev image (hot-reload via tsx). SCAFFOLD.
FROM node:20-slim

WORKDIR /app

# Install deps first (layer caching). No build step — tsx runs the TS directly.
COPY package.json ./
RUN npm install

COPY tsconfig.json server.ts ./

# Stateful mock listens on :4010 (note the port differs from real ops-core :4000).
ENV PORT=4010
EXPOSE 4010
CMD ["npx", "tsx", "watch", "server.ts"]
