# Frontend dev image — Vite dev server with HMR.
FROM node:20-alpine

# pnpm via Corepack so the image matches the repo's package manager.
RUN corepack enable

WORKDIR /app

# Install deps first so the layer caches across source-only changes. The
# lockfile is optional in the build context (dev compose bind-mounts source
# on top), so fall back to a plain install if it isn't present yet.
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install

# Seed the rest of the source for standalone builds; compose bind-mounts
# the live dev tree over these paths.
COPY . .

EXPOSE 5173

# Install at *startup*, not just build time: compose mounts a persistent
# `frontend_node_modules` volume over /app/node_modules that shadows the image's
# build-time install and survives rebuilds. Without this, adding a dependency
# (e.g. qrcode) to package.json leaves the container's node_modules stale and
# Vite fails to resolve the import. The bind-mounted package.json + lockfile are
# current, so a frozen install reconciles the volume without mutating either.
# --host so the dev server is reachable from outside the container.
CMD ["sh", "-c", "pnpm install --frozen-lockfile && pnpm dev --host 0.0.0.0"]
