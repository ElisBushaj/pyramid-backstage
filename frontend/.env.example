# Frontend (Vite) environment. Copy to `.env` for local dev. Only VITE_*-prefixed
# vars are exposed to the SPA bundle.

# ops-core API base. The client (src/api/client.ts) prefixes every request path
# with this. Includes the /api/v1 mount.
VITE_OPS_CORE_URL=http://localhost:4000/api/v1

# ai-orchestrator origin (chat / plan endpoints live on the Python side).
VITE_AI_URL=http://localhost:8000
