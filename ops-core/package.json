{
  "name": "pyramid-ops-core",
  "version": "1.0.0",
  "description": "Pyramid Backstage — deterministic system of record (Express 5 + Prisma 7 + Postgres + NATS)",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "dev": "cross-env NODE_ENV=development ts-node src/index.ts",
    "dev:watch": "cross-env NODE_ENV=development nodemon --exec ts-node src/index.ts",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev && prisma generate",
    "db:migrate:prod": "prisma migrate deploy && prisma generate",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:reset": "tsx src/scripts/seed.ts --reset",
    "db:studio": "prisma studio",
    "create:admin": "tsx src/scripts/create-admin.ts",
    "gen:types": "tsx src/scripts/gen-types.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:verify": "vitest run src/__tests__/demo.test.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^3.1.0",
    "dotenv": "^17.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.0.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "nats": "^2.29.0",
    "pg": "^8.13.0",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "prisma": "^7.8.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "yaml": "^2.9.0"
  }
}
