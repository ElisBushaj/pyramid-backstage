# Dev image for ops-core. Source is bind-mounted by docker-compose for hot reload.
FROM node:20-slim

# Prisma needs openssl
RUN apt-get update -y && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json ./
RUN npm install

COPY prisma ./prisma
RUN npx prisma generate

COPY . .

EXPOSE 4000
# Regenerate the Prisma client at *startup*, not just build time: compose mounts a
# persistent `ops_core_node_modules` volume over /app/node_modules that shadows the
# image's build-time client and survives rebuilds. Without this, adding a model to
# the schema (e.g. AssetMovement) leaves the container running a stale client and
# ts-node crashes on `prisma.<newModel>`. The bind-mounted prisma/ dir is current,
# so generating here always matches the live schema.
# Apply pending migrations on startup too — a fresh DB (new volume) has no tables
# otherwise, so seeding/queries fail with P2021. migrate deploy is idempotent.
# Then regenerate the client (see note above) and run the dev server.
CMD ["sh", "-c", "npx prisma migrate deploy && npx prisma generate && npm run dev:watch"]
