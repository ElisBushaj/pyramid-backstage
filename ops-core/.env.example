# ops-core environment. Copy to .env for local (non-docker) runs.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://pyramid:pyramid@localhost:5432/pyramid
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=change-me-in-prod
SESSION_TTL_HOURS=12
# F17 — shared bearer secret the ai-orchestrator uses to call ops-core (system actor).
# It forwards the acting staff user via X-Acting-User-Id / X-Acting-User-Role. Empty = disabled.
OPS_CORE_SERVICE_TOKEN=
HOLD_MINUTES_DEFAULT=30
VAT_RATE=0.20
LOG_LEVEL=debug
