# =============================================================================
# Pyramid Backstage — PRODUCTION env (docker-compose.prod.yml).
#
# In normal operation CI writes /opt/pyramid/.env from GitHub secrets — you do
# NOT create this by hand. This file documents every variable and is handy for a
# manual deploy on the VPS. NEVER commit a filled-in copy.
#   cp .env.prod.example .env   # then fill the blanks
# =============================================================================

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=pyramid
POSTGRES_USER=pyramid
POSTGRES_PASSWORD=            # long random string — `openssl rand -hex 24`

# ── ops-core ────────────────────────────────────────────────────────────────
SESSION_SECRET=              # `openssl rand -hex 32`
FRONTEND_URL=https://pyramidsolvers.xyz

# ── AI service token (must match on ops-core + ai-orchestrator) ─────────────
OPS_CORE_SERVICE_TOKEN=      # `openssl rand -hex 32`
ACTING_USER_ID=c0000000-0000-4000-8000-000000000002
ACTING_USER_ROLE=MANAGER

# ── Anthropic / models ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=           # sk-ant-... (ROTATE the one currently in the repo's dev .env)
MODEL=claude-opus-4-8
FAST_MODEL=claude-sonnet-4-6

# ── TLS ─────────────────────────────────────────────────────────────────────
LETSENCRYPT_EMAIL=           # you@example.com — for Let's Encrypt expiry notices

# ── Image overrides (optional — default to ghcr.io/elisbushaj/pyramid-backstage/*) ──
# OPS_CORE_IMAGE=ghcr.io/elisbushaj/pyramid-backstage/ops-core:latest
# AI_IMAGE=ghcr.io/elisbushaj/pyramid-backstage/ai-orchestrator:latest
# FRONTEND_IMAGE=ghcr.io/elisbushaj/pyramid-backstage/frontend:latest
