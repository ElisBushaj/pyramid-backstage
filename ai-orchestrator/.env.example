# ai-orchestrator — copy to `.env` and adjust. SCAFFOLD.

# ── THE one coupling to ops-core ─────────────────────────────────────────────
# Real ops-core (default):
OPS_CORE_URL=http://localhost:4000/api/v1
# Build against the stateful mock instead (the conflict 409 path is real there):
# OPS_CORE_URL=http://localhost:4010/api/v1

# ── F17 service-token auth — ONLY for the real ops-core; leave empty for the mock ─
# Must equal ops-core's OPS_CORE_SERVICE_TOKEN. Empty => no auth headers are sent.
OPS_CORE_SERVICE_TOKEN=
# The staff user the AI acts for (defaults to the seeded manager; role <= MANAGER):
ACTING_USER_ID=c0000000-0000-4000-8000-000000000002
ACTING_USER_ROLE=MANAGER

# ── Claude / Anthropic (optional in the scaffold — the graph nodes are stubs) ─
# Model id is the exact string below (Anthropic's most capable Opus-tier model).
ANTHROPIC_API_KEY=
MODEL=claude-opus-4-8

# ── Conversation state (Redis) + RAG (ChromaDB) ──────────────────────────────
REDIS_URL=redis://localhost:6379/0
CHROMA_URL=http://localhost:8001

# ── CORS — comma-separated frontend origins allowed to call this service ─────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
